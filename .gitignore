# Python
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Environment variables (private)
.env

# Credentials (private)
credentials.json

# Docker override (private local config)
infra/docker-compose.override.yml

# IDE (private)
.vscode/
.idea/

# OS (system)
.DS_Store
Thumbs.db

# Logs (private)
data/logs/*
!data/logs/.gitkeep

# Temp files
*.tmp
*.bak
*.backup*

# Node modules (generated)
node_modules/

# Input files (user documents - private)
input/

# OpenCode local cache (private)
.opencode/

# Generated files that should NOT be in repo (output is NOT here - should be tracked)
output/projects/
output/archive/

# Graphify cache (regenerable)
graphify-out/cache/

# Browsers (Playwright - regenerable)
browsers/

# Graphify output (regenerable)
graphify-out/

# Output generated files (all)
output/

# Data projects (test files)
data/projects/
