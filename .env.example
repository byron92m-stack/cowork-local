# Cowork-Local: Environment Variables Template
# Copy this file to .env and fill in your values
# ⚠️  NEVER commit .env to version control

# ─── Required ───────────────────────────────────────────────

# DeepSeek API Key (get yours at https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-key-here

# PostgreSQL (must match docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cowork
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=coworkdb

# ─── Optional: Override default paths ───────────────────────

# COWORK_ROOT=/path/to/cowork-local
# COWORK_PROJECTS=/path/to/your/projects
# OLLAMA_MODELS=/path/to/ollama-models
# DOCKER_DATA=/path/to/docker-data

# ─── Optional: Integrations ─────────────────────────────────

# GitHub (for GitHub skill)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Slack (for Slack skill)
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# Gmail (for Email skill)
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# GitLab (for GitLab skill)
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Notion (for Notion skill)
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
